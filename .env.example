# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Algolia
EXPO_PUBLIC_ALGOLIA_APP_ID=your-algolia-app-id
EXPO_PUBLIC_ALGOLIA_SEARCH_KEY=your-search-only-api-key
ALGOLIA_ADMIN_KEY=your-admin-api-key

# Google Maps
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# PostHog Analytics
EXPO_PUBLIC_POSTHOG_API_KEY=your-posthog-api-key
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# App Config
EXPO_PUBLIC_APP_URL=https://rasa.app
EXPO_PUBLIC_APP_ENV=development
